# Dockerfile.ui — Streamlit Web UI Container
# =============================================
# Lighter than the API container — only needs streamlit + requests.

FROM python:3.11-slim

WORKDIR /app

# Install only UI dependencies
RUN pip install --no-cache-dir streamlit==1.35.0 requests==2.32.0

# Copy the UI directory
COPY ui/ ./ui/

EXPOSE 8501

# --server.address 0.0.0.0 = listen on all interfaces
# --server.headless true    = no browser auto-open in Docker
CMD ["streamlit", "run", "ui/app.py", \
     "--server.port", "8501", \
     "--server.address", "0.0.0.0", \
     "--server.headless", "true"]
