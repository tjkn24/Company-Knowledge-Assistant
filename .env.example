# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Agent Platform Configuration
# Copy to .env and fill in your values.
# NEVER commit .env to git — it's already in .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────────────────────
# local = Ollama (free, runs on your machine)
# cloud = OpenAI GPT-4o-mini (requires API key, costs money)
# auto  = try local first, fall back to cloud
LLM_PROVIDER=auto
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral
OPENAI_API_KEY=sk-YOUR-KEY-HERE
OPENAI_MODEL=gpt-4o-mini

# ── RAG Mode ──────────────────────────────────────────────────────────────────
# standard = one search → one answer (fast, cheap)
# agentic  = agent searches multiple times (thorough, more tokens)
# auto     = picks based on query complexity (recommended)
RAG_MODE=auto
RAG_AUTO_THRESHOLD_WORDS=15

# ── Auth / Security ───────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-ME-GENERATE-WITH-COMMAND-ABOVE
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
COST_LIMIT_TOKENS_PER_RUN=4000
COST_LIMIT_USD_PER_RUN=0.05
RATE_LIMIT_PER_MINUTE=20
MAX_INPUT_LENGTH=2000

# ── Database ──────────────────────────────────────────────────────────────────
# Change this:
# DATABASE_URL=sqlite+aiosqlite:////app/data/agent.db
# To this (replace 'yourusername' with your actual Mac username):
DATABASE_URL=sqlite+aiosqlite:////Users/tjkn/company-knowledge-assistant-rev3-mcp-main/local_storage.db

# ── TELEGRAM (user channel) ───────────────────────────────────────────────────
# HOW TO GET:
#   1. Message @BotFather on Telegram → /newbot → follow prompts → copy token
#   2. Generate secret: python -c "import secrets; print(secrets.token_hex(16))"
#   3. For dev: ngrok http 8000 → copy the https:// URL
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=https://your-public-domain.com

# ── WHATSAPP via Twilio (user channel) ────────────────────────────────────────
# HOW TO GET:
#   1. console.twilio.com → Messaging → Try WhatsApp → Sandbox
#   2. Scan QR with phone → activate sandbox
#   3. Copy SID and Auth Token from console dashboard
#   4. Set webhook: https://your-domain.com/webhooks/whatsapp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── SLACK (user channel) ──────────────────────────────────────────────────────
# HOW TO GET:
#   1. api.slack.com/apps → Create App → OAuth & Permissions
#   2. Add scopes: chat:write, commands
#   3. Install to workspace → copy Bot Token
#   4. Basic Information → copy Signing Secret
#   5. Slash Commands → /ask → URL: https://your-domain.com/webhooks/slack
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=#general

# ── Email (outbound from agent tools) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
EMAIL_FROM=your@gmail.com

# ── n8n Traffic Manager ───────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
N8N_WEBHOOK_SECRET=CHANGE-ME-GENERATE-RANDOM
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_BASE_URL=http://n8n:5678
N8N_ENCRYPTION_KEY=CHANGE-ME-GENERATE-RANDOM

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
LOG_LEVEL=INFO

# ── External APIs ─────────────────────────────────────────────────────────────
WEATHER_API_KEY=

# ── MCP Server ─────────────────────────────────────────────────────────────────
# Exposes a subset of agent tools over the Model Context Protocol so Claude
# Desktop, Claude Code, n8n's MCP node, etc. can call them directly.
# "streamable-http" (default) runs as a Docker service at http://localhost:8800/mcp
# "stdio" is for local-process MCP clients (e.g. Claude Desktop) — see mcp_server/README.md
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8800
# Optional. If set, streamable-http requests must send: Authorization: Bearer <key>
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
MCP_API_KEY=
